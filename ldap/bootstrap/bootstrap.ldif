# admin user
dn: cn=admin,dc=ljcomputing,dc=net
changetype: add
objectClass: simpleSecurityObject
objectClass: organizationalRole
cn: admin
userPassword: admin
description: LDAP Administrator

# organisational unit for all users
dn: ou=users,dc=ljcomputing,dc=net
changetype: add
objectClass: organizationalUnit
ou: users

# organisational unit for IT department
dn: ou=IT,dc=ljcomputing,dc=net
changetype: add
objectClass: organizationalUnit
ou: IT

# organisational unit for marketing department
dn: ou=Marketing,dc=ljcomputing,dc=net
changetype: add
objectClass: organizationalUnit
ou: Marketing

# organisational unit for groups
dn: ou=groups,dc=ljcomputing,dc=net
changetype: add
objectClass: organizationalUnit
ou: groups

# user: John Doe for unit IT department
dn: uid=johndoe,ou=users,dc=ljcomputing,dc=net
changetype: add
objectClass: inetOrgPerson
cn: John Doe
sn: Doe
uid: johndoe
ou: IT
mail: johndoe@example.org
userPassword: password123

# user: Anna Meier for unit IT department
dn: uid=anna.meier,ou=users,dc=ljcomputing,dc=net
changetype: add
objectClass: inetOrgPerson
cn: Anna Meier
sn: Meier
uid: anna.meier
ou: IT
mail: anna.meier@example.org
userPassword: password456

# user: Peter Schmidt for the marketing department
dn: uid=peter.schmidt,ou=users,dc=ljcomputing,dc=net
changetype: add
objectClass: inetOrgPerson
cn: Peter Schmidt
sn: Schmidt
uid: peter.schmidt
ou: Marketing
mail: peter.schmidt@example.org
userPassword: password789

# group: IT department members
dn: cn=IT,ou=groups,dc=ljcomputing,dc=net
changetype: add
objectClass: groupOfNames
cn: IT
member: uid=johndoe,ou=users,dc=ljcomputing,dc=net
member: uid=anna.meier,ou=users,dc=ljcomputing,dc=net

# group: Marketing department members
dn: cn=Marketing,ou=groups,dc=ljcomputing,dc=net
changetype: add
objectClass: groupOfNames
cn: Marketing
member: uid=peter.schmidt,ou=users,dc=ljcomputing,dc=net
